<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Regular_12">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontWeight">400</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="Regular_16">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontWeight">400</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="Medium_16">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontWeight">500</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="Medium_22">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontWeight">500</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="Medium_32">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:fontWeight">700</item>
        <item name="android:fontFamily">@font/ys_display_bold</item>
    </style>

    <style name="Botton_blue">
        <item name="android:background">@color/blue</item>
        <item name="cornerRadius">@dimen/layout_12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontWeight">500</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="Botton_red">
        <item name="android:background">?attr/white_black</item>
        <item name="android:textColor">@color/red</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontWeight">500</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="NavigationButtonStyle">
        <item name="android:fontFamily">@font/ys_text_regular</item>
        <item name="itemTextColor">@color/gray</item>
        <item name="itemIconTint">@color/gray</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">?attr/colorPrimary</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
    </style>

</resources>
