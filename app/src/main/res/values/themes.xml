<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PracticumAndroidDiploma" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:screenOrientation">portrait</item>

        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="white_black">@color/white</item>
        <item name="black_white">@color/black</item>
        <item name="white_gray">@color/white</item>
        <item name="gray_white">@color/gray</item>
    </style>
</resources>
