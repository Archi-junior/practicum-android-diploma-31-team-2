<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/layout_8dp"
    android:paddingHorizontal="@dimen/layout_16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivCompanyLogo"
        android:layout_width="@dimen/layout_48dp"
        android:layout_height="@dimen/layout_48dp"
        android:background="@drawable/bg_logo_white"
        android:src="@drawable/ic_placeholder_employer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@drawable/ic_placeholder_employer" />

    <TextView
        android:id="@+id/tvVacancyName"
        style="@style/Medium_16"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/layout_12dp"
        android:layout_marginEnd="@dimen/layout_8dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintStart_toEndOf="@id/ivCompanyLogo"
        app:layout_constraintTop_toTopOf="@id/ivCompanyLogo"
        tools:text="Android-разработчик" />

    <TextView
        android:id="@+id/tvCompanyName"
        style="@style/Regular_12"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/layout_4dp"
        android:layout_marginStart="@dimen/layout_12dp"
        android:layout_marginEnd="@dimen/layout_8dp"
        android:maxLines="1"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintStart_toEndOf="@id/ivCompanyLogo"
        app:layout_constraintTop_toBottomOf="@id/tvVacancyName"
        tools:text="Яндекс" />

    <TextView
        android:id="@+id/tvSalary"
        style="@style/Regular_12"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/layout_2dp"
        android:layout_marginStart="@dimen/layout_12dp"
        android:layout_marginEnd="@dimen/layout_8dp"
        android:maxLines="1"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintStart_toEndOf="@id/ivCompanyLogo"
        app:layout_constraintTop_toBottomOf="@id/tvCompanyName"
        tools:text="от 100 000 ₽" />

</androidx.constraintlayout.widget.ConstraintLayout>
