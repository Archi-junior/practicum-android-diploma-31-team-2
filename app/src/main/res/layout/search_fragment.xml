<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary"
    tools:context=".ui.search.SearchFragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/leftBorder16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="@dimen/layout_16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/rightBorder16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="@dimen/layout_16dp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/searchEditText"
        style="@style/Regular_16"
        android:layout_width="@dimen/layout_0dp"
        android:layout_height="@dimen/layout_56dp"
        android:autofillHints=""
        android:background="@drawable/bg_light_gray"
        android:drawableEnd="@drawable/ic_search"
        android:hint="@string/enter_request"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="@dimen/layout_16dp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray"
        android:textCursorDrawable="@drawable/bg_cursor"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/quantityVacancy"
        style="@style/Regular_16"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/layout_12dp"
        android:background="@drawable/bg_blue"
        android:paddingHorizontal="@dimen/layout_12dp"
        android:paddingVertical="@dimen/layout_8dp"
        android:textColor="@color/white"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toBottomOf="@id/searchEditText" />

    <ImageView
        android:id="@+id/imageSearch"
        android:layout_width="@dimen/layout_0dp"
        android:layout_height="@dimen/layout_0dp"
        android:src="@drawable/image_search"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toBottomOf="@+id/searchEditText"
        app:layout_constraintVertical_bias="0.5" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="@dimen/layout_48dp"
        android:layout_height="@dimen/layout_48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toBottomOf="@+id/searchEditText"
        tools:ignore="MissingConstraints" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/vacancyRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/layout_8dp"
        android:paddingBottom="70dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toBottomOf="@id/quantityVacancy" />

    <LinearLayout
        android:id="@+id/footerProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:id="@+id/progressBarPagination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/blue" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/placeholderContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightBorder16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder16dp"
        app:layout_constraintTop_toBottomOf="@id/searchEditText">

        <include
            android:id="@+id/noInternetRoot"
            layout="@layout/placeholder_no_internet"
            android:visibility="gone" />

        <include
            android:id="@+id/serverErrorRoot"
            layout="@layout/placeholder_server_error"
            android:visibility="gone" />

        <include
            android:id="@+id/emptyRoot"
            layout="@layout/placeholder_empty"
            android:visibility="gone" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
